    {
      "@id": "#karrkany",
      "@type": "RepositoryObject",
      "name": "karrkany",
      "datePublished": "2016-11-08 01:36:17",
      "custom:translation": "Black Kite or Chickenhawk",
      "custom:sentence": "Karrkany-ju-ma ngumpit nguyina panana kurnpirlirn-pirrji. Karnti ngurla-nyanta nyanuny puya-ngarna yuwanana. Nyamu-wa nyila-ma ngumpit-ma panana karrkany-ju-ma karrinyana nyangunyangu na.",
      "custom:sentenceTranslation": "This bird makes Aboriginal people into traditional healers. It does this by throwing a stick at someone's body. When bird hits the person with a stick, they become a traditional healer or 'clever man'.",
      "custom:photographerName": "Bob Gosford",
      "custom:scientificName": "Milvus migrans",
      "pcdm:memberOf": {
        "@id": "./"
      },
      "speaker": {
        "@id": "#VioletWadrill"
