    {
      "@id": "#wintuk",
      "@type": "RepositoryObject",
      "name": "wintuk",
      "datePublished": "2016-11-08 01:36:17",
      "custom:translation": "Bush Stone Curlew",
      "custom:sentence": "Wankaj nyila-ma jurlak-ma. Nyantu-ma yanana ngu wurinykarra-la marnana ngu, murluwu-ma wawurru-la-ma. Yalanginyi-ma waninyana na. Jurrkjurrkkarra na karru-ma-nga. Wal kuyangka na, nyamu-lu ngarturr-jawung-kulu-ma kurru-ma nyangana yijarni ngulu jurlak kayi panana, karu-ngku-ma yalungku-ma, nyamu-ma born wanku.",
      "custom:sentenceTranslation": "This bird is dangerous. It walks along whistling in the scrub, then it falls over and convulses. When it gets up, that's when, if expectant mothers hear it, their babies will have fits when they're born.",
      "custom:photographerName": "Tom and Marie Tarrant",
      "custom:scientificName": "Burhinus grallarius",
      "pcdm:memberOf": {
        "@id": "./"
      },
      "speaker": {
        "@id": "#VioletWadrill"
      },
      "license": {
