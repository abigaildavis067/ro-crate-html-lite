    {
      "@id": "#kawulnga",
      "@type": "RepositoryObject",
      "name": "kawulnga",
      "alternateName": "parrakparrak",
      "datePublished": "2016-11-08 01:36:17",
      "custom:translation": "Nankeen Night Heron",
      "custom:sentence": "Kawulnga-ma marnana, \"Kawu-kawu!\" Lintarr na nguyina marnana nyamu wankaj ngumpit yanana.",
      "custom:sentenceTranslation": "This bird calls out \"Kawu-kawu!\" When you hear it calling, it is signalling that a dangerous kidney fat man from the north is approaching.",
