    {
      "@id": "#jiwayurru",
      "@type": "RepositoryObject",
      "name": "jiwayurru",
      "datePublished": "2016-11-08 01:36:17",
      "custom:translation": "Bowerbird or Stealing bird",
      "custom:sentence": "Manana ngu murlukun, needle-ma nyampa-ma everything warrwarrkuj jiwawurru-lu. Yuwanana ngu nyanuny-ja ngurra-ngka. Jiwayurru-ma nyila-ma jawurrapkaji ngulu tal panana.",
      "custom:sentenceTranslation": "This bird takes glass, needles or anything shiny and puts them in its nest. We call this bird a 'stealing bird'.",
      "custom:photographerName": "Bob Gosford",
      "custom:scientificName": "Chalmydera nuchalis",
      "pcdm:memberOf": {
