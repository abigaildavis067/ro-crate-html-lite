    {
      "@id": "#jikirrij",
      "@type": "RepositoryObject",
      "name": "jikirrij",
      "datePublished": "2016-11-08 01:36:17",
      "custom:translation": "Willy Wagtail",
      "custom:sentence": "Nyamu-n-nga parru tampang nyila-ma jikirrij-ma, ngamayi-ma ngu tampang karru kuya. Kuyaji na nyawa-ma. Marnani ngulu-rla, nyawa-wu-ma jikirrij-ku-ma. Nomo parra, kuya, ngaja ngamayi ngaji ngaja-ngkulu tampang karru. ",
      "custom:sentenceTranslation": "Your mother will die if you kill a willy wagtail. That's what they used to say about the willy-wagtail. \"Don't kill it, or your mother and father might die!\"",
      "custom:photographerName": "Barry McDonald",
      "custom:scientificName": "Rhipidura leucophrys",
      "pcdm:memberOf": {
